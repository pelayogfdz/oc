     <script>
         
//menu **********************************
document.addEventListener('click', function(e) {
    // Manejo de Menú Principal (Gatos/Perros)
    if (e.target.closest('.menu-trigger')) {
        e.preventDefault();
        const parent = e.target.closest('.has-dropdown');
        const menu = parent.querySelector('.dropdown-content');
        
        // Cerrar otros menús principales
        document.querySelectorAll('.dropdown-content').forEach(m => {
            if (m !== menu) m.classList.remove('is-visible');
        });
        
        menu.classList.toggle('is-visible');
    }

    // Manejo de Submenú (Alimentos)
    if (e.target.closest('.submenu-trigger')) {
        e.preventDefault();
        const subMenu = e.target.closest('.has-submenu').querySelector('.submenu-content');
        subMenu.classList.toggle('is-visible');
    }

    // Cerrar todo si haces clic fuera
    if (!e.target.closest('.has-dropdown')) {
        document.querySelectorAll('.dropdown-content, .submenu-content').forEach(m => {
            m.classList.remove('is-visible');
        });
    }
});

         
     </script>
     
    <script>
async function gestionarIdentificador() {
    // 1. Intentar obtener el ID del almacenamiento permanente del navegador
    let dispositivoId = localStorage.getItem('id_unico_navegador');

    // 2. Llamar a id.php enviando el ID (si existe)
    // Usamos FormData para que PHP lo reciba en el array $_POST
    const data = new FormData();
    if (dispositivoId) {
        data.append('dispositivo_id', dispositivoId);
    }

    try {
        const respuesta = await fetch('id.php', {
            method: 'POST',
            body: data
        });

        const resultado = await respuesta.json();

        // 3. Si el servidor nos devuelve un ID nuevo (porque no teníamos uno), lo guardamos
        if (resultado.status === 'success') {
            if (!dispositivoId) {
                localStorage.setItem('id_unico_navegador', resultado.id);
                console.log("Nuevo ID guardado localmente:", resultado.id);
            } else {
                console.log("Sesión restaurada con ID:", resultado.id);
            }
        }
    } catch (error) {
        console.error("Error conectando con id.php:", error);
    }
}

// Ejecutar al cargar la página
window.onload = gestionarIdentificador;
</script>
