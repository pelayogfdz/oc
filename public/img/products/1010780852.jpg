    <script>
        function manejarNavegacion() {
            const hash = window.location.hash || '#inicio';
            
            // Ocultar todas
            document.querySelectorAll('.seccion').forEach(s => s.classList.remove('activa'));
            
            // Mostrar la seleccionada
            const destino = document.querySelector(hash);
            if (destino) {
                destino.classList.add('activa');
            }
        }

        // Eventos para el cambio de hash y carga inicial
        window.addEventListener('hashchange', manejarNavegacion);
        window.addEventListener('load', manejarNavegacion);
        
        
        //****************************************************************
        document.addEventListener("DOMContentLoaded", () => {
            
    const modal = document.getElementById("modalProducto");
    const btnCerrar = document.querySelector(".close-modal");
    const contenidoModal = document.getElementById('contenidoModal');
     
    const input = document.getElementById('input_busqueda');
    const sugerencias = document.getElementById('resultados_sugeridos');
    //const modal = document.getElementById('modalProducto');
    const boton = document.getElementById('bbuscar');
    const divResultados = document.getElementById('dresultados');
   
    let timer;

    // 1. Buscador en tiempo real
    input.addEventListener('input', () => {
        clearTimeout(timer);
        const query = input.value.trim();

        if (query.length < 3) {
            sugerencias.style.display = 'none';
            return;
        }

        timer = setTimeout(() => {
            fetch('/productos/buscar.php', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `query=${encodeURIComponent(query)}`
            })
            .then(res => res.text())
            .then(html => {
                sugerencias.innerHTML = html;
                sugerencias.style.display = 'block';
            });
        }, 300);
    });

    // 2. Clic en una sugerencia -> Abre Modal con detalle
    document.addEventListener('click', (e) => {
        // Si hace clic en un resultado de búsqueda
        if (e.target.closest('.item-sugerido')) {
            const item = e.target.closest('.item-sugerido');
            const idProd = item.dataset.id;
            
            sugerencias.style.display = 'none';
            abrirModal(idProd);
        }

        // Cerrar sugerencias al hacer clic fuera
        if (!e.target.closest('.search-engine-container')) {
            sugerencias.style.display = 'none';
        }
        // ******************************************************
        // Detectar click en cualquier enlace "Ver [+]"
   
        if (e.target.classList.contains("ver-mas")) {
            const idProd = e.target.getAttribute("data-id");
            sugerencias.style.display = 'none';
            //alert("hola1");
             abrirModal(idProd);
             
            modal.style.display = "block";

          
        }
        
        if (e.target.classList.contains('bbuscar')) {
        const query = input.value.trim();
        //const idProducto = e.target.getAttribute('data-id');
        console.log("Abrir producto con ID:", encodeURIComponent(query));
        //abrirModal(idProducto); // Llamas a tu función del modal
          fetch('/productos/buscarb.php', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `query=${encodeURIComponent(query)}`
            })
            .then(res => res.text())
            .then(html => {
                divResultados.innerHTML = html;
                //divResultados.style.display = 'block';
            });
    }
        
        
        
    });

    function abrirModal(id) {
        modal.style.display = 'block';
        contenidoModal.innerHTML = '<p>Cargando detalles...</p>';
        
        fetch(`/productos/detalleproducto.php?id=${id}`)
            .then(res => res.text())
            .then(html => {
                contenidoModal.innerHTML = html;
            });
    }
    
    

    // Cerrar modal
    document.querySelector('.close-modal').onclick = () => modal.style.display = 'none';
    window.onclick = (e) => { if (e.target == modal) modal.style.display = 'none'; };
});
    </script>
    
