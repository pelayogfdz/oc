<script>
document.addEventListener("DOMContentLoaded", () => {
    // ID del DIV que quieres mostrar/ocultar
    const divAlerta = document.getElementById('miDivAlerta');
    const divCarroM = document.getElementById('DivCarro');
    function consultarEstado() {
        // Realizamos la petición POST a datos.php
        fetch('/productos/cdatos.php', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            // Si necesitas enviar parámetros, van aquí: body: 'usuario=123'
            body: '' 
        })
        .then(response => response.json()) // Esperamos una respuesta tipo JSON (true o false)
        .then(res => {
            if (res === true) {
                divAlerta.style.display = 'block'; // Mostrar
                divCarroM.style.display = 'block'; // Mostrar
            } else {
                divAlerta.style.display = 'none';  // Ocultar
                divCarroM.style.display = 'none';  // Ocultar
                
            }
        })
        .catch(error => {
            console.error('Error al conectar con datos.php:', error);
        });
    }

    // Ejecutar la función inmediatamente al cargar la página
    consultarEstado();

    // Configurar el intervalo para que se repita cada 5000ms (5 segundos)
    setInterval(consultarEstado, 5000);
});
</script><script>
    // --- FUNCIÓN PARA ASIGNAR COOKIE DE USUARIO (Si no existe) ---
    // Esto simula un ID de sesión para el carrito
    function gestionarCookieUsuario() {
        const nombreCookie = "idu";
        // Buscamos si la cookie ya existe
        let cookies = document.cookie.split(';').some(c => c.trim().startsWith(nombreCookie + '='));
        
        if (!cookies) {
            // Creamos un ID aleatorio para el ejemplo (o puedes traerlo de tu BD)
            const idAleatorio = Math.floor(Math.random() * 10000);
            // La cookie expirará en 7 días y es válida para toda la web (path=/)
            document.cookie = `${nombreCookie}=${idAleatorio}; max-age=${60*60*24*7}; path=/`;
            console.log("Nueva cookie de usuario creada:", idAleatorio);
        }
    }

    // Ejecutamos la gestión de cookie al cargar la página
    gestionarCookieUsuario();
//cookies       *********************************

    document.getElementById('btn_suscribir').addEventListener('click', function() {
    const email = document.getElementById('email_boletin').value;
    const checkboxTerminos = document.getElementById('check_boletin'); // El ID de tu checkbox
    const mensaje = document.getElementById('mensaje_status');

if (!email.includes('@')) {
        //alert("Por favor, ingresa un correo válido.");
        // 1. Cambiamos el texto
    mensaje.innerText = "Por favor, ingresa un correo válido.";
    
    // 2. CAMBIO CLAVE: Cambiamos el estilo para que deje de estar oculto
    mensaje.style.display = "block"; 
    
    // 3. Aseguramos el color (opcional si ya está en el HTML)
    mensaje.style.color = "red";
        return;
    }
    
    if (!checkboxTerminos.checked) {
    // 1. Cambiamos el texto
    mensaje.innerText = "Debe aceptar los términos y condiciones";
    
    // 2. CAMBIO CLAVE: Cambiamos el estilo para que deje de estar oculto
    mensaje.style.display = "block"; 
    
    // 3. Aseguramos el color (opcional si ya está en el HTML)
    mensaje.style.color = "red";
        return;
    }
    
   

    // Detectar dispositivo (Simple)
    const dispositivo = /Mobi|Android/i.test(navigator.userAgent) ? "Celular" : "PC";
    const pagina = window.location.href;

    // Enviar datos por AJAX (Fetch)
    fetch('registro.php', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `correo=${encodeURIComponent(email)}&dispositivo=${dispositivo}&pagina=${pagina}`
    })
    .then(response => response.text())
    .then(data => {
        mensaje.innerText = "Hemos registrado su correo. ¡Gracias!";
        mensaje.style.color = "green";
        mensaje.style.display = "block";
        document.getElementById('email_boletin').value = ""; // Limpiar input
    })
    .catch(error => console.error('Error:', error));
});

/**
 * CONFIGURACIÓN DE RUTAS
 */
const mediaConfig = {
    // Configuración para Computadoras (Horizontal)
    desktop: {
        videos: [
            
            'img/slides/castell_v_h1.mp4'
        ],
        images: [
            //'img/slides/Banner_index.webp',
            'img/slides/h1.jpeg',
            'img/slides/h2.jpeg',
            'img/slides/h3.jpeg'
        ]
    },
    // Configuración para Celulares (Vertical 1:1)
    mobile: {
        videos: [
           'img/slides/vv1.mp4'
        ],
        images: [
            'img/slides/cuadro1.jpeg',
            'img/slides/cuadro2.jpeg',
            'img/slides/cuadro3.jpeg'
        ]
    }
};

const videoElement = document.getElementById('main-video');
const videoWrapper = document.getElementById('video-wrapper');
const sliderWrapper = document.getElementById('slider-wrapper');
const slidesContainer = document.getElementById('slides-container');

const isMobile = window.innerWidth <= 768;
const currentSet = isMobile ? mediaConfig.mobile : mediaConfig.desktop;

let currentVideoIdx = 0;
let currentSlideIdx = 0;

function initMedia() {
    // Inyectar imágenes
    currentSet.images.forEach((ruta, index) => {
        const img = document.createElement('img');
        img.src = ruta;
        img.classList.add('slide-img');
        slidesContainer.appendChild(img);
    });
    
    //loadVideo(currentVideoIdx);
    transitionToSlider();
}

function loadVideo(index) {
    videoElement.src = currentSet.videos[index];
    videoElement.load();
    videoElement.play().catch(e => console.log("Play bloqueado por el navegador"));
}

videoElement.onended = function() {
    currentVideoIdx++;
    if (currentVideoIdx < currentSet.videos.length) {
        loadVideo(currentVideoIdx);
    } else {
        transitionToSlider();
    }
};

function transitionToSlider() {
    videoWrapper.style.display = 'none';
    sliderWrapper.style.display = 'block';
    
    const allSlides = document.querySelectorAll('.slide-img');
    currentSlideIdx = 0;
    
    // Mostrar primera imagen
    allSlides.forEach(img => img.classList.remove('active'));
    allSlides[0].classList.add('active');
    
    let slideInterval = setInterval(() => {
        allSlides[currentSlideIdx].classList.remove('active');
        currentSlideIdx++;

        if (currentSlideIdx < allSlides.length) {
            allSlides[currentSlideIdx].classList.add('active');
        } else {
            clearInterval(slideInterval);
            //resetToVideo();
            transitionToSlider2();
        }
    }, 3500); // 3 segundos por imagen
}

function transitionToSlider2() {
    videoWrapper.style.display = 'none';
    sliderWrapper.style.display = 'block';
    
    const allSlides = document.querySelectorAll('.slide-img');
    currentSlideIdx = 0;
    
    // Mostrar primera imagen
    allSlides.forEach(img => img.classList.remove('active'));
    allSlides[0].classList.add('active');
    
    let slideInterval = setInterval(() => {
        allSlides[currentSlideIdx].classList.remove('active');
        currentSlideIdx++;

        if (currentSlideIdx < allSlides.length) {
            allSlides[currentSlideIdx].classList.add('active');
        } else {
            clearInterval(slideInterval);
            //resetToVideo();
            transitionToSlider();
        }
    }, 3500); // 3 segundos por imagen
}

function resetToVideo() {
    currentSlideIdx = 0;
    currentVideoIdx = 0;
    sliderWrapper.style.display = 'none';
    videoWrapper.style.display = 'block';
    
    // Limpiar clases para el próximo ciclo
    document.querySelectorAll('.slide-img').forEach(img => img.classList.remove('active'));
    
    loadVideo(currentVideoIdx);
}

initMedia();


function cambiarGrid(gridId, elemento) {
    // 1. Ocultar todas las cuadrículas de productos
    document.querySelectorAll('.grid-vendedores').forEach(grid => {
        grid.classList.remove('activa');
    });

    // 2. Mostrar la cuadrícula seleccionada
    const destino = document.getElementById(gridId);
    if (destino) {
        destino.classList.add('activa');
    }

    // 3. (Opcional) Cambiar el estilo del botón para saber cuál está activo
    document.querySelectorAll('.sales-nav a').forEach(link => {
        link.classList.remove('activa');
    });
    elemento.classList.add('activa');
}
//boton carro
    document.querySelectorAll('.btn-cart').forEach(boton => {
 boton.addEventListener('click', () => {
            
            const productDetails = boton.closest('.product-details'); // Referencia al contenedor padre
            //const nombreProducto = productDetails.querySelector('.p-name').innerText;
        const idProducto = boton.getAttribute('data-id');
        // --- NUEVA LÍNEA: Capturar el valor del select ---
        
        // Buscamos el select con clase 'unidades' dentro del mismo contenedor del producto
            
            const cantidadProducto = productDetails.querySelector('.btn-cantidad').value;
            const textoOriginal = boton.innerHTML;
            //const cantidadProducto = boton.closest('.product-details').querySelector('.btn-cantidad').value;
            const nombreProducto = boton.closest('.product-details').querySelector('.p-name').innerText;
//alert(`¡Éxito! Se agregó "${nombreProducto}" - Unidad: "${idProducto}" al carrito.`);
// Bloqueo visual del botón
boton.disabled = true;
boton.style.opacity = "0.5";
boton.style.cursor = "not-allowed";
boton.innerHTML = "<i>⌛</i> Agregando...";

const formData = new FormData();

formData.append('cantidad', cantidadProducto);
formData.append('id_producto', idProducto);
 // Fetch enviará automáticamente la cookie 'idusuario_cook' en los headers
fetch('/productos/carro.php', {
method: 'POST',
body: formData
})
.then(res => res.json())
.then(data => {
if(data.status === 'success') {
alert(`¡Éxito! Se agregó "${nombreProducto}" - Unidad: "${cantidadProducto}" al carrito.`);
} else {
alert('Error: ' + data.message);
}
})
.catch(error => {
console.error('Error:', error);
alert('Hubo un error en la conexión.');
})
.finally(() => {
// Rehabilitar tras 3 segundos
setTimeout(() => {
boton.disabled = false;
boton.style.opacity = "1";
boton.style.cursor = "pointer";
boton.innerHTML = textoOriginal;
 }, 3000);
});
      });
});
</script>
</body>
</html>