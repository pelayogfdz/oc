datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

model Tenant {
  id          String    @id @default(uuid())
  name        String
  slug        String?   @unique
  isActive    Boolean   @default(true)
  trialEndsAt DateTime? // Optional field to manage 5-day trial
  decimals    Int       @default(2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  giftCredits        Float   @default(0)
  mpCustomerId       String?
  mpCardId           String?
  subscriptionStatus String  @default("TRIAL") // TRIAL, ACTIVE, PAST_DUE, CANCELED
  customBasePrice    Float?
  customUserPrice    Float?

  users    User[]
  branches Branch[]
}

model SystemSettings {
  id            String   @id @default(uuid())
  mpAccessToken String?  @db.Text
  mpPublicKey   String?  @db.Text
  basePrice     Float    @default(0)
  userPrice     Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id                        String                   @id @default(uuid())
  name                      String
  email                     String                   @unique
  password                  String
  forcePasswordChange       Boolean                  @default(false)
  role                      String                   @default("USER")
  isSuperAdmin              Boolean                  @default(false)
  permissions               String? // JSON string
  
  tenantId                  String?
  tenant                    Tenant?                  @relation(fields: [tenantId], references: [id])

  branch                    Branch?                  @relation(fields: [branchId], references: [id])
  branchId                  String?
  
  sales                     Sale[]
  quotes                    Quote[]
  purchases                 Purchase[]
  purchaseOrders            PurchaseOrder[]
  expenses                  Expense[]
  cashSessions              CashSession[]
  inventoryMovements        InventoryMovement[]
  inventoryAdjustmentDocs   InventoryAdjustmentDoc[]
  customerPayments          CustomerPayment[]
  supplierPayments          SupplierPayment[]
  returns                   SaleReturn[]
  transfersCreated          Transfer[]               @relation("TransferCreatedBy")
  transfersReceived         Transfer[]               @relation("TransferReceivedBy")
  transfersRequested        Transfer[]               @relation("TransferRequestedBy")
  transfersDispatched       Transfer[]               @relation("TransferDispatchedBy")
  purchaseRequestsRequested PurchaseRequest[]
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  // Jerarquía y Comisiones (Coordinador -> Líder -> Vendedor)
  managerId    String?
  manager      User?   @relation("UserManager", fields: [managerId], references: [id])
  subordinates User[]  @relation("UserManager")

  commissionRole  String? // 'VENDEDOR', 'LIDER', 'COORDINADOR'
  commissionPct   Float   @default(0) // Porcentaje de comisión 
  monthlyGoal     Float   @default(0) // Meta individual o de equipo
  bonusAmount     Float   @default(0) // Bono personal central
  teamBonusAmount Float   @default(0) // Bono que se otorga extra a los subordinados si el equipo llega a la meta

  // --- HR & Payroll (MCOMX Integration) ---
  rfc                 String?
  curp                String?
  nss                 String?
  taxRegime           String?
  address             String?
  phone               String?
  hireDate            DateTime?
  birthDate           DateTime?
  
  payrollType         String? // 'SEMANAL', 'QUINCENAL', etc.
  dailySalary         Float   @default(0)
  bankName            String?
  bankAccount         String?
  
  bonusPunctuality    Float   @default(0)
  bonusRule           String?
  bonusMethod         String?
  overtimeBonus       Float   @default(0)
  groceryBonus        Float   @default(0)
  transportBonus      Float   @default(0)
  
  faceDescriptor      String? // JSON array or string
  baselinePhoto       String? @db.Text
  reqGps              Boolean @default(false)
  reqPhoto            Boolean @default(false)
  
  homeLat             Float?
  homeLng             Float?
  homeRadius          Float?  @default(50)
  
  workScheduleMatrix  String? // JSON string containing schedule Mon-Sun
  
  attendanceLogs      AttendanceLog[]
  leaveRequests       LeaveRequest[]
}

model Branch {
  id                      String                   @id @default(uuid())
  name                    String
  location                String?

  tenantId                String?
  tenant                  Tenant?                  @relation(fields: [tenantId], references: [id])

  users                   User[]
  customers               Customer[]
  products                Product[]
  sales                   Sale[]
  quotes                  Quote[]
  transfersFrom           Transfer[]               @relation("TransferFrom")
  transfersTo             Transfer[]               @relation("TransferTo")
  promotions              Promotion[]
  suppliers               Supplier[]
  purchases               Purchase[]
  purchaseOrders          PurchaseOrder[]
  expenses                Expense[]
  priceLists              PriceList[]
  cashSessions            CashSession[]
  inventoryAudits         InventoryAudit[]
  inventoryAdjustmentDocs InventoryAdjustmentDoc[]
  storeIntegrations       StoreIntegration[]
  customerPayments        CustomerPayment[]
  supplierPayments        SupplierPayment[]
  settings                BranchSettings?
  returns                 SaleReturn[]
  purchaseRequests        PurchaseRequest[]
  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  
  hrLocation              HrLocation?
}

model BranchSettings {
  id       String @id @default(uuid())
  branchId String @unique
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  ticketHeader   String?
  ticketFooter   String?
  taxIVA         Float   @default(16.0)
  currencySymbol String  @default("$")

  autoCloseCash Boolean  @default(false)
  useCustomCFDI Boolean  @default(false)
  configJson    String? // JSON config for all 18 tabs
  updatedAt     DateTime @updatedAt
}

model Customer {
  id       String  @id @default(uuid())
  name     String
  phone            String?
  email            String?
  additionalEmails String?
  branch           Branch? @relation(fields: [branchId], references: [id])
  branchId         String?
  sales    Sale[]
  quotes   Quote[]

  // Dirección Completa
  street         String?
  exteriorNumber String?
  interiorNumber String?
  neighborhood   String?
  city           String?
  state          String?

  // Datos Fiscales
  taxId     String?
  legalName String?
  taxRegime String?
  zipCode   String?
  cfdiUse   String?

  // Crédito y Finanzas
  creditLimit   Float  @default(0)
  creditDays    Int    @default(0)
  creditBalance Float  @default(0) // Debe (lo que el cliente debe)
  storeCredit   Float  @default(0) // Saldo a favor
  priceList     String @default("price") // price, wholesalePrice, specialPrice

  payments CustomerPayment[]

  isBlocked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerPayment {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  amount     Float
  reason     String?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])

  saleId     String?
  sale       Sale?    @relation(fields: [saleId], references: [id])
  cfdiStatus String   @default("NONE") // NONE, REQUESTED, TIMBRADO
  cfdiUrlPdf String?
  cfdiUrlXml String?
  paymentDate DateTime?

  createdAt  DateTime @default(now())
}

model SupplierPayment {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  amount     Float
  reason     String?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])

  purchaseId String?
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])
  cfdiStatus String    @default("NONE") // NONE, REQUESTED, TIMBRADO
  cfdiUrlPdf String?
  cfdiUrlXml String?

  createdAt  DateTime @default(now())
}

model Product {
  id                  String               @id @default(uuid())
  sku                 String
  barcode             String?
  name                String
  description         String?
  price               Float
  wholesalePrice      Float?
  specialPrice        Float?
  cost                Float                @default(0) // Costo de Reposición
  averageCost         Float                @default(0) // Costo Promedio
  taxRate             Float                @default(16.0)
  category            String?
  brand               String?
  imageUrl            String?
  youtubeUrl          String? // <-- Video de demostración o reseña
  isActive            Boolean              @default(true)
  unit                String               @default("Pza")
  stock               Int                  @default(0)
  minStock            Int                  @default(0)
  branch              Branch               @relation(fields: [branchId], references: [id])
  branchId            String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  saleItems           SaleItem[]
  inventoryMovements  InventoryMovement[]
  quoteItems          QuoteItem[]
  transferItems       TransferItem[]
  purchaseItems       PurchaseItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  supplierId          String?
  supplier            Supplier?            @relation(fields: [supplierId], references: [id])
  prices              ProductPrice[]
  variants            ProductVariant[] // <-- New: Tallas y Colores
  inventoryAuditItems InventoryAuditItem[]
  externalMaps        ExternalProductMap[]
  purchaseRequests    PurchaseRequest[]
  satKey              String? // Clave de producto o servicio en el SAT
  satUnit             String? // Clave de unidad de medida en el SAT

  @@unique([sku, branchId])
  @@index([branchId, stock])
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute String // Ej: "L - Rojo" o "32 GB"
  sku       String?
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems          SaleItem[]
  quoteItems         QuoteItem[]
  transferItems      TransferItem[]
  inventoryMovements InventoryMovement[]

  @@unique([productId, attribute])
}

model InventoryMovement {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      String // "IN", "OUT", "ADJUSTMENT"
  quantity  Int // Positive for additions, negative for subtractions
  reason    String // Reason for the movement (e.g. "Initial Stock", "Sale #123")
  createdAt DateTime @default(now())

  userId    String?
  user      User?           @relation(fields: [userId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  adjustmentDocId String?
  adjustmentDoc   InventoryAdjustmentDoc? @relation(fields: [adjustmentDocId], references: [id], onDelete: Cascade)
}

model Sale {
  id            String       @id @default(uuid())
  total         Float
  status        String       @default("COMPLETED")
  paymentMethod String       @default("CASH")
  customer      Customer?    @relation(fields: [customerId], references: [id])
  customerId    String?
  branch        Branch?      @relation(fields: [branchId], references: [id])
  branchId      String?
  user          User         @relation(fields: [userId], references: [id])
  userId        String
  cashSessionId String?
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])

  // Novedades para Multi-pago y Notas
  notes      String?
  cashAmount Float?
  cardAmount Float?

  invoiceId     String?
  satCreditNote String?
  dueDate       DateTime? // Vencimiento si es a crédito
  balanceDue    Float     @default(0) // Saldo pendiente

  items     SaleItem[]
  returns   SaleReturn[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  payments  CustomerPayment[] // Pagos a esta factura

  @@index([branchId, createdAt(sort: Desc)])
}

model SaleItem {
  id        String           @id @default(uuid())
  quantity  Int
  price     Float
  sale      Sale             @relation(fields: [saleId], references: [id])
  saleId    String
  product   Product          @relation(fields: [productId], references: [id])
  productId String
  variantId String?
  variant   ProductVariant?  @relation(fields: [variantId], references: [id])
  returns   SaleReturnItem[]
}

model SaleReturn {
  id       String @id @default(uuid())
  saleId   String
  sale     Sale   @relation(fields: [saleId], references: [id])
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  totalRefund   Float
  refundMethod  String  @default("CASH") // CASH, CARD, STORE_CREDIT
  reason        String?
  satCreditNote String? // Nota de credito del SAT para esta devolucion

  items     SaleReturnItem[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model SaleReturnItem {
  id           String     @id @default(uuid())
  saleReturnId String
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  saleItemId   String
  saleItem     SaleItem   @relation(fields: [saleItemId], references: [id])
  quantity     Int
  refundPrice  Float
}

model Quote {
  id            String      @id @default(uuid())
  total         Float
  status        String      @default("PENDING")
  paymentMethod String      @default("CASH")
  customer      Customer?   @relation(fields: [customerId], references: [id])
  customerId    String?
  branch        Branch?     @relation(fields: [branchId], references: [id])
  branchId      String?
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  items         QuoteItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model QuoteItem {
  id        String          @id @default(uuid())
  quantity  Int
  price     Float
  quote     Quote           @relation(fields: [quoteId], references: [id])
  quoteId   String
  product   Product         @relation(fields: [productId], references: [id])
  productId String
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
}

model Transfer {
  id         String  @id @default(uuid())
  branch     Branch? @relation("TransferFrom", fields: [branchId], references: [id])
  branchId   String?
  toBranch   Branch? @relation("TransferTo", fields: [toBranchId], references: [id])
  toBranchId String?
  status     String  @default("REQUESTED") // REQUESTED, CREATED, DISPATCHED, RECEIVED

  requestedById  String?
  requestedBy    User?   @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  createdById    String?
  createdBy      User?   @relation("TransferCreatedBy", fields: [createdById], references: [id])
  dispatchedById String?
  dispatchedBy   User?   @relation("TransferDispatchedBy", fields: [dispatchedById], references: [id])
  receivedById   String?
  receivedBy     User?   @relation("TransferReceivedBy", fields: [receivedById], references: [id])

  requestedAt  DateTime? @default(now())
  dispatchedAt DateTime?
  receivedAt   DateTime?

  items            TransferItem[]
  purchaseRequests PurchaseRequest[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model TransferItem {
  id         String          @id @default(uuid())
  quantity   Int
  transfer   Transfer        @relation(fields: [transferId], references: [id])
  transferId String
  product    Product         @relation(fields: [productId], references: [id])
  productId  String
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id])

  cost        Float @default(0) // Costo de Reposición al hacer el traspaso
  averageCost Float @default(0) // Costo Promedio al hacer el traspaso
}

model Promotion {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("PERCENTAGE")
  value     Float    @default(0)
  active    Boolean  @default(true)
  branch    Branch   @relation(fields: [branchId], references: [id])
  branchId  String
  metadata  String? // JSON con filtros: { applyToBrands: [], applyToCategories: [], applyToProducts: [], minQuantity: 2 }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id             String     @id @default(uuid())
  name           String
  email          String?
  additionalEmails String?
  phone          String?
  street         String?
  exteriorNumber String?
  interiorNumber String?
  neighborhood   String?
  branchId       String?
  branch         Branch?    @relation(fields: [branchId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  purchases      Purchase[]
  purchaseOrders PurchaseOrder[]
  products       Product[]

  // Datos Fiscales
  taxId     String?
  legalName String?
  taxRegime String?
  zipCode   String?
  cfdiUse   String?

  // Dirección adicional
  city  String?
  state String?

  // Crédito
  creditLimit Float @default(0)
  creditDays  Int   @default(0)
  creditBalance Float @default(0) // Saldo global deudor
  storeCredit   Float @default(0) // Saldo a favor / Anticipos

  payments    SupplierPayment[]
}

model Purchase {
  id            String         @id @default(uuid())
  branchId      String?
  branch        Branch?        @relation(fields: [branchId], references: [id])
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  supplierId    String?
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  total         Float
  paymentMethod String         @default("CASH") // CASH, CARD, TRANSFER, CREDIT
  freightCost   Float?         @default(0)
  status        String         @default("COMPLETED") // COMPLETED, PENDING
  
  dueDate       DateTime?      // Vencimiento si es a crédito
  balanceDue    Float          @default(0) // Saldo pendiente
  
  createdAt     DateTime       @default(now())
  items         PurchaseItem[]
  payments      SupplierPayment[] // Pagos a esta factura
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Int
  cost       Float
}

model PriceList {
  id            String         @id @default(uuid())
  branchId      String
  branch        Branch         @relation(fields: [branchId], references: [id])
  name          String // e.g. "Público", "Mayoreo"
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  productPrices ProductPrice[]
}

model ProductPrice {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  price       Float

  @@unique([productId, priceListId])
}

model CashSession {
  id       String  @id @default(uuid())
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])
  userId   String
  user     User    @relation(fields: [userId], references: [id])

  openedAt DateTime  @default(now())
  closedAt DateTime?

  initialAmount  Float
  expectedAmount Float?
  actualAmount   Float?
  difference     Float?

  status String @default("OPEN")

  movements CashMovement[]
  sales     Sale[]
}

model CashMovement {
  id        String      @id @default(uuid())
  sessionId String
  session   CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String // IN, OUT
  amount    Float
  reason    String
  createdAt DateTime    @default(now())
}

model StoreIntegration {
  id           String   @id @default(uuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id])
  platform     String // MERCADO_LIBRE, SHOPIFY, WOOCOMMERCE
  appId        String?
  clientSecret String?
  accessToken  String?
  refreshToken String?
  isActive     Boolean  @default(true)
  metadata     String? // JSON context (like seller_id)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([branchId, platform])
}

model ExternalProductMap {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  platform   String // MERCADO_LIBRE
  externalId String // ID en la plataforma externa (MLM12345)
  syncStatus String   @default("SYNCED") // UNSYNCED, SYNCED, ERROR
  lastSync   DateTime @default(now())

  @@unique([platform, externalId])
}

model Expense {
  id        String   @id @default(uuid())
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  category  String // e.g., "Renta", "Nómina", "Luz", "Otros"
  amount    Float
  reason    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryAudit {
  id        String   @id @default(uuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  name      String
  status    String   @default("COUNT_1") // COUNT_1, COUNT_2, COUNT_3, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items InventoryAuditItem[]
}

model InventoryAuditItem {
  id        String         @id @default(uuid())
  auditId   String
  audit     InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id], onDelete: Restrict)

  systemStock Int // Frozen stock reading at beginning of audit

  count1     Int? // Primer Conteo
  count2     Int? // Segundo Conteo
  count3     Int? // Tercer Conteo
  finalCount Int? // Resultado final para ajustar
}

model InventoryAdjustmentDoc {
  id        String   @id @default(uuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  reason    String // Razón global (Ej. "Mercancía maltratada", "Donación")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  movements InventoryMovement[]
}

model PurchaseRequest {
  id        String  @id @default(uuid())
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id])
  
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  preProductName String? // Para productos fuera de catálogo
  
  quantity  Int
  status    String  @default("PENDING") // PENDING, ORDERED, REJECTED

  transferId String? // Optional link to the transfer that originated this
  transfer   Transfer? @relation(fields: [transferId], references: [id])

  requestedById String
  requestedBy   User     @relation(fields: [requestedById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PurchaseOrder {
  id            String              @id @default(uuid())
  branchId      String?
  branch        Branch?             @relation(fields: [branchId], references: [id])
  supplierId    String?
  supplier      Supplier?           @relation(fields: [supplierId], references: [id])
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  total         Float
  status        String              @default("PENDING")
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  items         PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String         @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity        Int
  cost            Float
}

model AttendanceLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // 'IN' or 'OUT'
  timestamp   DateTime @default(now())
  lat         Float?
  lng         Float?
  photoUrl    String?  // Could be base64 or a URL
  deviceInfo  String?
  status      String   @default("OK") // OK, LATE, MANUAL, etc.
}

model LeaveRequest {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // 'VACATION', 'PERM_PAID', 'PERM_UNPAID'
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Course {
  id          String   @id @default(uuid())
  title       String
  youtubeUrl  String
  description String?
  createdAt   DateTime @default(now())
}

model HrLocation {
  id          String   @id @default(uuid())
  name        String
  lat         Float
  lng         Float
  radius      Float    @default(50) // in meters
  branchId    String?  @unique
  branch      Branch?  @relation(fields: [branchId], references: [id])
}

