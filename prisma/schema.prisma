generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String                 @id @default(uuid())
  name                 String
  slug                 String?                @unique
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  decimals             Int                    @default(2)
  timezone             String                 @default("America/Mexico_City")
  trialEndsAt          DateTime?
  giftCredits          Float                  @default(0)
  mpCardId             String?
  mpCustomerId         String?
  subscriptionStatus   String                 @default("TRIAL")
  customBasePrice      Float?
  customUserPrice      Float?
  branches             Branch[]
  HrLocation           HrLocation[]
  ManufacturingProcess ManufacturingProcess[]
  Recipe               Recipe[]
  users                User[]
  customRoles          CustomRole[]
}

model SystemSettings {
  id            String   @id @default(uuid())
  mpAccessToken String?
  mpPublicKey   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  basePrice     Float    @default(0)
  userPrice     Float    @default(0)
}

model User {
  id                        String                   @id @default(uuid())
  name                      String
  email                     String                   @unique
  password                  String
  role                      String                   @default("USER")
  permissions               String?
  branchId                  String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  bonusAmount               Float                    @default(0)
  commissionPct             Float                    @default(0)
  commissionRole            String?
  managerId                 String?
  monthlyGoal               Float                    @default(0)
  teamBonusAmount           Float                    @default(0)
  tenantId                  String?
  address                   String?
  bankAccount               String?
  bankName                  String?
  birthDate                 DateTime?
  bonusMethod               String?
  bonusPunctuality          Float                    @default(0)
  bonusRule                 String?
  curp                      String?
  dailySalary               Float                    @default(0)
  faceDescriptor            String?
  groceryBonus              Float                    @default(0)
  hireDate                  DateTime?
  nss                       String?
  overtimeBonus             Float                    @default(0)
  payrollType               String?
  phone                     String?
  reqGps                    Boolean                  @default(false)
  flexibleGps               Boolean                  @default(false)
  reqPhoto                  Boolean                  @default(false)
  rfc                       String?
  taxRegime                 String?
  transportBonus            Float                    @default(0)
  workScheduleMatrix        String?
  baselinePhoto             String?
  forcePasswordChange       Boolean                  @default(false)
  homeLat                   Float?
  homeLng                   Float?
  homeRadius                Float?                   @default(50)
  isSuperAdmin              Boolean                  @default(false)
  deductLunchHour           Boolean                  @default(false)
  strictCheckinTime         Boolean                  @default(false)
  currentSessionId          String?
  webauthnCredentialId      String?
  webauthnPublicKey         String?
  attendanceLogs            AttendanceLog[]
  cashSessions              CashSession[]
  customerPayments          CustomerPayment[]
  deliveryOrders            DeliveryOrder[]          @relation("DriverOrders")
  expenses                  Expense[]
  inventoryAdjustmentDocs   InventoryAdjustmentDoc[]
  inventoryMovements        InventoryMovement[]
  leaveRequests             LeaveRequest[]
  ProductionOrder           ProductionOrder[]
  prospects                 Prospect[]               @relation("AssignedProspects")
  purchases                 Purchase[]
  purchaseOrders            PurchaseOrder[]
  purchaseRequestsRequested PurchaseRequest[]
  quotes                    Quote[]
  consignments              Consignment[]
  sales                     Sale[]
  returns                   SaleReturn[]
  supplierPayments          SupplierPayment[]
  transfersCreated          Transfer[]               @relation("TransferCreatedBy")
  transfersDispatched       Transfer[]               @relation("TransferDispatchedBy")
  transfersReceived         Transfer[]               @relation("TransferReceivedBy")
  transfersRequested        Transfer[]               @relation("TransferRequestedBy")
  branch                    Branch?                  @relation(fields: [branchId], references: [id])
  manager                   User?                    @relation("UserManager", fields: [managerId], references: [id])
  subordinates              User[]                   @relation("UserManager")
  tenant                    Tenant?                  @relation(fields: [tenantId], references: [id])
  hrLocations               HrLocation[]             @relation("UserHrLocations")
  appointments              Appointment[]
  assignedTasks             CollaboratorTask[]       @relation("AssignedTasks")
  createdTasks              CollaboratorTask[]       @relation("CreatedTasks")
  customRoleId              String?
  customRole                CustomRole?              @relation(fields: [customRoleId], references: [id])
}

model CustomRole {
  id          String   @id @default(uuid())
  name        String
  description String?
  permissions String   // JSON string storing the permissions object
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Branch {
  id                      String                   @id @default(uuid())
  name                    String
  location                String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  isActive                Boolean                  @default(true)
  tenantId                String?
  tenant                  Tenant?                  @relation(fields: [tenantId], references: [id])
  settings                BranchSettings?
  loyaltySettings         LoyaltySettings?
  cashSessions            CashSession[]
  customers               Customer[]
  appointments            Appointment[]
  customerPayments        CustomerPayment[]
  expenses                Expense[]
  hrLocation              HrLocation?
  inventoryAdjustmentDocs InventoryAdjustmentDoc[]
  inventoryAudits         InventoryAudit[]
  priceLists              PriceList[]
  products                Product[]
  ProductionOrder         ProductionOrder[]
  promotions              Promotion[]
  prospects               Prospect[]
  purchases               Purchase[]
  purchaseOrders          PurchaseOrder[]
  purchaseRequests        PurchaseRequest[]
  quotes                  Quote[]
  consignments            Consignment[]
  sales                   Sale[]
  returns                 SaleReturn[]
  storeIntegrations       StoreIntegration[]
  suppliers               Supplier[]
  supplierPayments        SupplierPayment[]
  transfersFrom           Transfer[]               @relation("TransferFrom")
  transfersTo             Transfer[]               @relation("TransferTo")
  users                   User[]
  whatsappSessions        WhatsAppSession?
  collaboratorTasks       CollaboratorTask[]
  fuelTransactions        FuelTransaction[]
}

model BranchSettings {
  id             String   @id @default(uuid())
  branchId       String   @unique
  ticketHeader   String?
  ticketFooter   String?
  taxIVA         Float    @default(16.0)
  currencySymbol String   @default("$")
  autoCloseCash  Boolean  @default(false)
  configJson     String?
  updatedAt      DateTime @updatedAt
  useCustomCFDI  Boolean  @default(false)
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Customer {
  id               String            @id @default(uuid())
  name             String
  phone            String?
  email            String?
  branchId         String?
  street           String?
  exteriorNumber   String?
  interiorNumber   String?
  neighborhood     String?
  city             String?
  state            String?
  taxId            String?
  legalName        String?
  taxRegime        String?
  zipCode          String?
  cfdiUse          String?
  creditLimit      Float             @default(0)
  creditDays       Int               @default(0)
  priceList        String            @default("price")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  creditBalance    Float             @default(0)
  storeCredit      Float             @default(0)
  isBlocked        Boolean           @default(false)
  pointsBalance    Float             @default(0)
  pointsExpiryDate DateTime?
  additionalEmails String?
  branch           Branch?           @relation(fields: [branchId], references: [id])
  payments         CustomerPayment[]
  prospects        Prospect[]
  quotes           Quote[]
  consignments     Consignment[]
  sales            Sale[]
  loyaltyTransactions LoyaltyTransaction[]
  appointments     Appointment[]
  fuelTransactions FuelTransaction[]
}

model CustomerPayment {
  id          String    @id @default(uuid())
  customerId  String
  amount      Float
  reason      String?
  userId      String
  branchId    String?
  createdAt   DateTime  @default(now())
  cfdiStatus  String    @default("NONE")
  cfdiUrlPdf  String?
  cfdiUrlXml  String?
  saleId      String?
  paymentDate DateTime?
  branch      Branch?   @relation(fields: [branchId], references: [id])
  customer    Customer  @relation(fields: [customerId], references: [id])
  sale        Sale?     @relation(fields: [saleId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model SupplierPayment {
  id         String    @id @default(uuid())
  supplierId String
  amount     Float
  reason     String?
  userId     String
  branchId   String?
  purchaseId String?
  cfdiStatus String    @default("NONE")
  cfdiUrlPdf String?
  cfdiUrlXml String?
  createdAt  DateTime  @default(now())
  branch     Branch?   @relation(fields: [branchId], references: [id])
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}

model Product {
  id                  String               @id @default(uuid())
  sku                 String
  barcode             String?
  name                String
  description         String?
  price               Float
  wholesalePrice      Float?
  specialPrice        Float?
  cost                Float                @default(0)
  taxRate             Float                @default(16.0)
  category            String?
  brand               String?
  imageUrl            String?
  youtubeUrl          String?
  isActive            Boolean              @default(true)
  allowProduction     Boolean              @default(false)
  isProductionInput   Boolean              @default(false)
  isService           Boolean              @default(false)
  unit                String               @default("Pza")
  stock               Int                  @default(0)
  minStock            Int                  @default(0)
  expirationDate      DateTime?
  branchId            String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  supplierId          String?
  satKey              String?
  satUnit             String?
  averageCost         Float                @default(0)
  showInWeb           Boolean              @default(true)
  externalMaps        ExternalProductMap[]
  inventoryAuditItems InventoryAuditItem[]
  inventoryMovements  InventoryMovement[]
  branch              Branch               @relation(fields: [branchId], references: [id])
  supplier            Supplier?            @relation(fields: [supplierId], references: [id])
  batches             ProductBatch[]
  prices              ProductPrice[]
  variants            ProductVariant[]
  purchaseItems       PurchaseItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  purchaseRequests    PurchaseRequest[]
  quoteItems          QuoteItem[]
  consignmentItems    ConsignmentItem[]
  Recipe              Recipe?
  RecipeIngredient    RecipeIngredient[]
  saleItems           SaleItem[]
  transferItems       TransferItem[]
  hasTraceability     Boolean              @default(false)
  fuelTraceabilities  FuelTraceability[]
  priceChanges        PriceChangeLog[]

  @@unique([sku, branchId])
  @@index([branchId, stock])
}

model ProductVariant {
  id                 String              @id @default(uuid())
  productId          String
  attribute          String
  sku                String?
  stock              Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  quoteItems         QuoteItem[]
  consignmentItems   ConsignmentItem[]
  saleItems          SaleItem[]
  transferItems      TransferItem[]

  @@unique([productId, attribute])
}

model InventoryMovement {
  id              String                  @id @default(uuid())
  productId       String
  type            String
  quantity        Int
  reason          String
  createdAt       DateTime                @default(now())
  userId          String?
  variantId       String?
  adjustmentDocId String?
  batchId         String?
  adjustmentDoc   InventoryAdjustmentDoc? @relation(fields: [adjustmentDocId], references: [id], onDelete: Cascade)
  batch           ProductBatch?           @relation(fields: [batchId], references: [id])
  product         Product                 @relation(fields: [productId], references: [id])
  user            User?                   @relation(fields: [userId], references: [id])
  variant         ProductVariant?         @relation(fields: [variantId], references: [id])
}

model Sale {
  id            String            @id @default(uuid())
  folio         String?
  total         Float
  status        String            @default("COMPLETED")
  paymentMethod String            @default("CASH")
  customerId    String?
  branchId      String?
  userId        String
  cashSessionId String?
  notes         String?
  cashAmount    Float?
  cardAmount    Float?
  invoiceId     String?
  invoiceFolio  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  satCreditNote String?
  balanceDue    Float             @default(0)
  dueDate       DateTime?
  payments      CustomerPayment[]
  deliveryOrder DeliveryOrder?
  branch        Branch?           @relation(fields: [branchId], references: [id])
  cashSession   CashSession?      @relation(fields: [cashSessionId], references: [id])
  customer      Customer?         @relation(fields: [customerId], references: [id])
  user          User              @relation(fields: [userId], references: [id])
  items         SaleItem[]
  returns       SaleReturn[]
  fuelTransaction FuelTransaction?
  cartaPortes   CartaPorte[]

  @@index([branchId, createdAt(sort: Desc)])
}

model SaleItem {
  id        String           @id @default(uuid())
  quantity  Int
  price     Float
  saleId    String
  productId String
  variantId String?
  batchId   String?
  batch     ProductBatch?    @relation(fields: [batchId], references: [id])
  product   Product          @relation(fields: [productId], references: [id])
  sale      Sale             @relation(fields: [saleId], references: [id])
  variant   ProductVariant?  @relation(fields: [variantId], references: [id])
  returns   SaleReturnItem[]
  fuelTraceability FuelTraceability?
}

model SaleReturn {
  id            String           @id @default(uuid())
  saleId        String
  userId        String
  branchId      String
  totalRefund   Float
  refundMethod  String           @default("CASH")
  reason        String?
  satCreditNote String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  branch        Branch           @relation(fields: [branchId], references: [id])
  sale          Sale             @relation(fields: [saleId], references: [id])
  user          User             @relation(fields: [userId], references: [id])
  items         SaleReturnItem[]
}

model SaleReturnItem {
  id           String     @id @default(uuid())
  saleReturnId String
  saleItemId   String
  quantity     Int
  refundPrice  Float
  saleItem     SaleItem   @relation(fields: [saleItemId], references: [id])
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
}

model Quote {
  id            String      @id @default(uuid())
  folio         String?
  total         Float
  status        String      @default("PENDING")
  paymentMethod String      @default("CASH")
  customerId    String?
  branchId      String?
  userId        String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  branch        Branch?     @relation(fields: [branchId], references: [id])
  customer      Customer?   @relation(fields: [customerId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
  items         QuoteItem[]
}

model QuoteItem {
  id        String          @id @default(uuid())
  quantity  Int
  price     Float
  quoteId   String
  productId String
  variantId String?
  product   Product         @relation(fields: [productId], references: [id])
  quote     Quote           @relation(fields: [quoteId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
}

model Consignment {
  id            String            @id @default(uuid())
  folio         String?
  total         Float
  status        String            @default("PENDING") // PENDING, ACTIVE, CONVERTED
  paymentMethod String            @default("CASH")
  customerId    String?
  branchId      String?
  userId        String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  branch        Branch?           @relation(fields: [branchId], references: [id])
  customer      Customer?         @relation(fields: [customerId], references: [id])
  user          User              @relation(fields: [userId], references: [id])
  items         ConsignmentItem[]
}

model ConsignmentItem {
  id            String          @id @default(uuid())
  quantity      Int
  price         Float
  consignmentId String
  productId     String
  variantId     String?
  product       Product         @relation(fields: [productId], references: [id])
  consignment   Consignment     @relation(fields: [consignmentId], references: [id], onDelete: Cascade)
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
}


model Transfer {
  id               String            @id @default(uuid())
  folio            String?
  branchId         String?
  toBranchId       String?
  status           String            @default("REQUESTED")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdById      String?
  receivedById     String?
  dispatchedAt     DateTime?
  dispatchedById   String?
  receivedAt       DateTime?
  requestedAt      DateTime?         @default(now())
  requestedById    String?
  purchaseRequests PurchaseRequest[]
  branch           Branch?           @relation("TransferFrom", fields: [branchId], references: [id])
  createdBy        User?             @relation("TransferCreatedBy", fields: [createdById], references: [id])
  dispatchedBy     User?             @relation("TransferDispatchedBy", fields: [dispatchedById], references: [id])
  receivedBy       User?             @relation("TransferReceivedBy", fields: [receivedById], references: [id])
  requestedBy      User?             @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  toBranch         Branch?           @relation("TransferTo", fields: [toBranchId], references: [id])
  items            TransferItem[]
}

model TransferItem {
  id          String          @id @default(uuid())
  quantity    Int
  transferId  String
  productId   String
  variantId   String?
  averageCost Float           @default(0)
  cost        Float           @default(0)
  product     Product         @relation(fields: [productId], references: [id])
  transfer    Transfer        @relation(fields: [transferId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
}

model Promotion {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("PERCENTAGE")
  value     Float    @default(0)
  active    Boolean  @default(true)
  branchId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  metadata  String?
  branch    Branch   @relation(fields: [branchId], references: [id])
}

model Supplier {
  id               String            @id @default(uuid())
  name             String
  email            String?
  phone            String?
  street           String?
  exteriorNumber   String?
  interiorNumber   String?
  neighborhood     String?
  branchId         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  taxId            String?
  legalName        String?
  taxRegime        String?
  zipCode          String?
  cfdiUse          String?
  city             String?
  state            String?
  creditLimit      Float             @default(0)
  creditDays       Int               @default(0)
  creditBalance    Float             @default(0)
  storeCredit      Float             @default(0)
  additionalEmails String?
  products         Product[]
  purchases        Purchase[]
  purchaseOrders   PurchaseOrder[]
  branch           Branch?           @relation(fields: [branchId], references: [id])
  payments         SupplierPayment[]
  fuelTransactions FuelTransaction[]
}

model Purchase {
  id            String            @id @default(uuid())
  folio         String?
  supplierFolio String?
  branchId      String?
  userId        String
  supplierId    String?
  total         Float
  paymentMethod String            @default("CASH")
  status        String            @default("COMPLETED")
  createdAt     DateTime          @default(now())
  freightCost   Float?            @default(0)
  balanceDue    Float             @default(0)
  dueDate       DateTime?
  branch        Branch?           @relation(fields: [branchId], references: [id])
  supplier      Supplier?         @relation(fields: [supplierId], references: [id])
  user          User              @relation(fields: [userId], references: [id])
  items         PurchaseItem[]
  payments      SupplierPayment[]
  fuelTransaction FuelTransaction?
  cartaPortes   CartaPorte[]
}

model PurchaseItem {
  id         String        @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Int
  cost       Float
  batchId    String?
  batch      ProductBatch? @relation(fields: [batchId], references: [id])
  product    Product       @relation(fields: [productId], references: [id])
  purchase   Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  fuelTraceability FuelTraceability?
}

model PriceList {
  id            String         @id @default(uuid())
  branchId      String
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  branch        Branch         @relation(fields: [branchId], references: [id])
  productPrices ProductPrice[]
}

model ProductPrice {
  id          String    @id @default(uuid())
  productId   String
  priceListId String
  price       Float
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, priceListId])
}

model CashSession {
  id             String         @id @default(uuid())
  branchId       String?
  userId         String
  openedAt       DateTime       @default(now())
  closedAt       DateTime?
  initialAmount  Float
  expectedAmount Float?
  actualAmount   Float?
  difference     Float?
  status         String         @default("OPEN")
  notes          String?
  detailsJson    String?
  movements      CashMovement[]
  branch         Branch?        @relation(fields: [branchId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  sales          Sale[]
}

model CashMovement {
  id        String      @id @default(uuid())
  sessionId String
  type      String
  amount    Float
  reason    String
  createdAt DateTime    @default(now())
  session   CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model StoreIntegration {
  id           String   @id @default(uuid())
  branchId     String
  platform     String
  appId        String?
  clientSecret String?
  accessToken  String?
  refreshToken String?
  isActive     Boolean  @default(true)
  metadata     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  branch       Branch   @relation(fields: [branchId], references: [id])

  @@unique([branchId, platform])
}

model ExternalProductMap {
  id         String   @id @default(uuid())
  productId  String
  platform   String
  externalId String
  syncStatus String   @default("SYNCED")
  lastSync   DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([platform, externalId])
}

model Expense {
  id        String   @id @default(uuid())
  branchId  String?
  userId    String
  category  String
  amount    Float
  reason    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch?  @relation(fields: [branchId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model InventoryAudit {
  id        String               @id @default(uuid())
  branchId  String
  name      String
  status    String               @default("COUNT_1")
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  branch    Branch               @relation(fields: [branchId], references: [id])
  items     InventoryAuditItem[]
}

model InventoryAuditItem {
  id          String         @id @default(uuid())
  auditId     String
  productId   String
  systemStock Int
  count1      Int?
  count2      Int?
  count3      Int?
  finalCount  Int?
  audit       InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  product     Product        @relation(fields: [productId], references: [id])
}

model InventoryAdjustmentDoc {
  id        String              @id @default(uuid())
  branchId  String
  reason    String
  userId    String
  createdAt DateTime            @default(now())
  branch    Branch              @relation(fields: [branchId], references: [id])
  user      User                @relation(fields: [userId], references: [id])
  movements InventoryMovement[]
}

model PurchaseRequest {
  id             String    @id @default(uuid())
  branchId       String
  productId      String?
  quantity       Int
  status         String    @default("PENDING")
  transferId     String?
  requestedById  String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  preProductName String?
  branch         Branch    @relation(fields: [branchId], references: [id])
  product        Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  requestedBy    User      @relation(fields: [requestedById], references: [id])
  transfer       Transfer? @relation(fields: [transferId], references: [id])
}

model PurchaseOrder {
  id         String              @id @default(uuid())
  branchId   String?
  supplierId String?
  userId     String
  total      Float
  status     String              @default("PENDING")
  notes      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  branch     Branch?             @relation(fields: [branchId], references: [id])
  supplier   Supplier?           @relation(fields: [supplierId], references: [id])
  user       User                @relation(fields: [userId], references: [id])
  items      PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  cost            Float
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model AttendanceLog {
  id         String   @id @default(uuid())
  userId     String
  type       String
  timestamp  DateTime @default(now())
  lat        Float?
  lng        Float?
  photoUrl   String?
  deviceInfo String?
  status     String   @default("OK")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id        String   @id @default(uuid())
  userId    String
  type      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("PENDING")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id          String   @id @default(uuid())
  title       String
  youtubeUrl  String
  description String?
  createdAt   DateTime @default(now())
}

model HrLocation {
  id       String  @id @default(uuid())
  name     String
  lat      Float
  lng      Float
  radius   Float   @default(50)
  branchId String? @unique
  tenantId String?
  branch   Branch? @relation(fields: [branchId], references: [id])
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  users    User[]  @relation("UserHrLocations")
}

model DeliveryOrder {
  id              String    @id @default(uuid())
  saleId          String    @unique
  street          String?
  exteriorNumber  String?
  interiorNumber  String?
  neighborhood    String?
  city            String?
  state           String?
  zipCode         String?
  lat             Float?
  lng             Float?
  status          String    @default("PENDING")
  deliveryDate    DateTime?
  postponedTo     DateTime?
  driverId        String?
  evidencePhoto   String?
  notes           String?
  branchId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clientSignature String?
  routeOrder      Int       @default(0)
  driver          User?     @relation("DriverOrders", fields: [driverId], references: [id])
  sale            Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([deliveryDate])
}

model ProductBatch {
  id             String              @id @default(uuid())
  productId      String
  batchNumber    String?
  expirationDate DateTime?
  stock          Int                 @default(0)
  cost           Float               @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  movements      InventoryMovement[]
  product        Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseItems  PurchaseItem[]
  saleItems      SaleItem[]
  fuelTraceability FuelTraceability?

  @@index([productId, expirationDate])
}

model Prospect {
  id             String            @id @default(uuid())
  name           String
  phone          String?
  email          String?
  funnelStage    String            @default("NEW")
  branchId       String
  assignedUserId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  customerId     String?
  whatsappId     String?
  assignedUser   User?             @relation("AssignedProspects", fields: [assignedUserId], references: [id])
  branch         Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer       Customer?         @relation(fields: [customerId], references: [id])
  messages       WhatsAppMessage[]

  @@unique([phone, branchId])
}

model WhatsAppSession {
  id          String   @id @default(uuid())
  branchId    String   @unique
  status      String   @default("DISCONNECTED")
  sessionData String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model WhatsAppMessage {
  id         String   @id @default(uuid())
  messageId  String?  @unique
  prospectId String
  body       String
  isFromMe   Boolean  @default(false)
  status     Int      @default(0)
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

model WhatsAppMediaRequest {
  id        String   @id @default(uuid())
  messageId String   @unique
  status    String   @default("PENDING")
  mimetype  String?
  filename  String?
  data      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhatsAppSyncRequest {
  id        String   @id @default(uuid())
  branchId  String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ManufacturingProcess {
  id               String            @id @default(uuid())
  name             String
  order            Int
  tenantId         String?
  branchId         String?
  isActive         Boolean           @default(true)
  tenant           Tenant?           @relation(fields: [tenantId], references: [id])
  productionOrders ProductionOrder[]
}

model Recipe {
  id               String             @id @default(uuid())
  productId        String             @unique
  name             String
  instructions     String?
  tenantId         String?
  branchId         String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  productionOrders ProductionOrder[]
  product          Product            @relation(fields: [productId], references: [id])
  tenant           Tenant?            @relation(fields: [tenantId], references: [id])
  ingredients      RecipeIngredient[]
}

model RecipeIngredient {
  id        String  @id @default(uuid())
  recipeId  String
  productId String
  quantity  Float
  product   Product @relation(fields: [productId], references: [id])
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model ProductionOrder {
  id               String                @id @default(uuid())
  recipeId         String
  targetQuantity   Float
  status           String                @default("PENDING")
  currentProcessId String?
  branchId         String
  userId           String
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  branch           Branch                @relation(fields: [branchId], references: [id])
  currentProcess   ManufacturingProcess? @relation(fields: [currentProcessId], references: [id])
  recipe           Recipe                @relation(fields: [recipeId], references: [id])
  user             User                  @relation(fields: [userId], references: [id])
}

model LoyaltySettings {
  id              String   @id @default(uuid())
  branchId        String   @unique
  pointsPerAmount Float    @default(1.0)
  amountStep      Float    @default(100.0)
  paymentMethods  String   @default("CASH,CARD,TRANSFER")
  validityDays    Int      @default(365)
  isActive        Boolean  @default(true)
  pointsCash      Float    @default(1.0)
  pointsCard      Float    @default(1.0)
  pointsTransfer  Float    @default(1.0)
  pointsCredit    Float    @default(0.0)
  pointsMixto     Float    @default(1.0)
  pointValueInPesos Float  @default(1.0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model LoyaltyTransaction {
  id         String   @id @default(uuid())
  customerId String
  type       String   // "EARNED", "REDEEMED", "EXPIRED"
  points     Float
  reason     String?
  saleId     String?
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Appointment {
  id          String   @id @default(uuid())
  branchId    String
  customerId  String?
  userId      String?
  title       String
  notes       String?
  scheduledAt DateTime
  duration    Int      @default(30)
  clientName  String?
  clientPhone String?
  clientEmail String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CollaboratorTask {
  id             String    @id @default(uuid())
  title          String
  instructions   String
  assignedToId   String
  assignedTo     User      @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User      @relation("CreatedTasks", fields: [createdById], references: [id])
  branchId       String
  branch         Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  status         String    @default("PENDING") // "PENDING", "COMPLETED"
  recurrence     String    @default("ONCE") // "ONCE", "DAILY", "WEEKLY", "MONTHLY"
  dueDate        DateTime?
  evidenceFile   String?   // Archivo de evidencia en formato base64/dataURL
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model FuelTraceability {
  id                  String        @id @default(uuid())
  productId           String
  purchaseItemId      String?       @unique
  saleItemId          String?       @unique
  batchId             String?       @unique
  pedimento           String?       // Número de pedimento
  pedimentoDate       DateTime?
  crePermitSupplier   String?       // Permiso CRE del Proveedor
  crePermitCarrier    String?       // Permiso CRE del Transportista
  density             Float?        // Densidad (kg/m3)
  temperature         Float?        // Temperatura (°C)
  octane              Float?        // Octanaje / Calidad
  volume20c           Float?        // Volumen corregido a 20°C
  certNumber          String?       // Certificado de calidad
  createdAt           DateTime      @default(now())
  product             Product       @relation(fields: [productId], references: [id])
  purchaseItem        PurchaseItem? @relation(fields: [purchaseItemId], references: [id], onDelete: Cascade)
  saleItem            SaleItem?     @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  batch               ProductBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model FuelImport {
  id                String            @id @default(uuid())
  pedimentoNumber   String            @unique
  pedimentoDate     DateTime
  customsOffice     String?           // Aduana
  brokerName        String?           // Agente Aduanal
  countryOfOrigin   String            @default("USA")
  currency          String            @default("USD")
  exchangeRate      Float             @default(1.0)
  fobValue          Float             @default(0.0)
  freightCost       Float             @default(0.0)
  dtaAmount         Float             @default(0.0)
  prevAmount        Float             @default(0.0)
  ivaImport         Float             @default(0.0)
  totalCustomsTaxes Float             @default(0.0)
  status            String            @default("IN_TRANSIT") // IN_TRANSIT, CUSTOMS, RELEASED
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  transactions      FuelTransaction[]
}

model FuelTransaction {
  id                   String          @id @default(uuid())
  folio                String?         @unique
  branchId             String
  saleId               String?         @unique
  customerId           String?
  customerOrderDate    DateTime?
  deliveryDate         DateTime?
  actualDeliveryDate   DateTime?
  deliveryStatus       String          @default("PENDING") // PENDING, IN_TRANSIT, DELIVERED, CANCELLED
  purchaseId           String?         @unique
  supplierId           String?
  purchaseDate         DateTime?
  importId             String?
  
  // Documentos adjuntos
  purchaseReceipt      String?         // URL recibo compra
  supplierInvoice      String?         // URL factura proveedor
  shippingDoc          String?         // URL doc de embarque
  customerInvoice      String?         // URL factura venta
  evidencePhoto        String?         // Foto de entrega
  evidenceNotes        String?         
  
  // Costos logísticos y utilidad
  distanceKm           Float           @default(0)
  fuelPricePerLiter    Float           @default(0)
  vehicleKmPerLiter    Float           @default(1.0)
  wearCostPerKm        Float           @default(0)
  driverCostPerKm      Float           @default(0)
  extraLogisticsCost   Float           @default(0)
  calculatedLogisticsCost Float        @default(0)
  calculatedNetProfit  Float           @default(0)

  branch               Branch          @relation(fields: [branchId], references: [id])
  sale                 Sale?           @relation(fields: [saleId], references: [id], onDelete: SetNull)
  purchase             Purchase?       @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  customer             Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplier             Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  import               FuelImport?     @relation(fields: [importId], references: [id], onDelete: SetNull)
  cartaPortes          CartaPorte[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model CartaPorte {
  id                 String           @id @default(uuid())
  folio              String           @unique
  transactionId      String?
  saleId             String?
  purchaseId         String?
  uuidSat            String?
  xmlUrl             String?
  pdfUrl             String?
  status             String           @default("DRAFT") // DRAFT, TIMBRADO, CANCELADO
  carrierName        String?
  carrierRfc         String?
  vehiclePlate       String?
  trailerPlate       String?
  driverName         String?
  driverRfc          String?
  driverLicense      String?
  originAddress      String?
  destinationAddress String?
  distanceKm         Float?
  stampDate          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  transaction        FuelTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  sale               Sale?            @relation(fields: [saleId], references: [id], onDelete: SetNull)
  purchase           Purchase?        @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
}

model PriceChangeLog {
  id        String   @id @default(uuid())
  productId String
  oldPrice  Float
  newPrice  Float
  branchId  String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([branchId, createdAt])
}


