datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")
  permissions String? // JSON string
  branch    Branch?  @relation(fields: [branchId], references: [id])
  branchId  String?
  sales     Sale[]
  quotes    Quote[]
  purchases Purchase[]
  expenses  Expense[]
  cashSessions CashSession[]
  inventoryMovements InventoryMovement[]
  customerPayments CustomerPayment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  location  String?
  users     User[]
  customers Customer[]
  products  Product[]
  sales     Sale[]
  quotes    Quote[]
  transfersFrom Transfer[] @relation("TransferFrom")
  transfersTo   Transfer[] @relation("TransferTo")
  promotions    Promotion[]
  suppliers     Supplier[]
  purchases     Purchase[]
  expenses      Expense[]
  priceLists    PriceList[]
  cashSessions  CashSession[]
  inventoryAudits InventoryAudit[]
  storeIntegrations StoreIntegration[]
  customerPayments  CustomerPayment[]
  settings      BranchSettings?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BranchSettings {
  id              String   @id @default(uuid())
  branchId        String   @unique
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  
  ticketHeader    String?
  ticketFooter    String?
  taxIVA          Float    @default(16.0)
  currencySymbol  String   @default("$")
  
  autoCloseCash   Boolean  @default(false)
  configJson      String?  // JSON config for all 18 tabs
  updatedAt       DateTime @updatedAt
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  branchId  String?
  sales     Sale[]
  quotes    Quote[]
  
  // Dirección Completa
  street         String?
  exteriorNumber String?
  interiorNumber String?
  neighborhood   String?
  city      String?
  state     String?
  
  // Datos Fiscales
  taxId       String?
  legalName   String?
  taxRegime   String?
  zipCode     String?
  cfdiUse     String?
  
  // Crédito y Finanzas
  creditLimit Float    @default(0)
  creditDays  Int      @default(0)
  creditBalance Float  @default(0) // Debe (lo que el cliente debe)
  priceList   String   @default("price") // price, wholesalePrice, specialPrice
  
  payments    CustomerPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerPayment {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  amount      Float
  reason      String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  createdAt   DateTime @default(now())
}

model Product {
  id          String     @id @default(uuid())
  sku         String
  barcode     String?
  name        String
  description String?
  price       Float
  wholesalePrice Float?
  specialPrice Float?
  cost        Float      @default(0)
  taxRate     Float      @default(16.0)
  category    String?
  brand       String?
  imageUrl    String?
  youtubeUrl  String?    // <-- Video de demostración o reseña
  isActive    Boolean    @default(true)
  unit        String     @default("Pza")
  stock       Int        @default(0)
  minStock    Int        @default(0)
  branch      Branch     @relation(fields: [branchId], references: [id])
  branchId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]
  quoteItems         QuoteItem[]
  transferItems      TransferItem[]
  purchaseItems      PurchaseItem[]
  supplierId         String?
  supplier           Supplier?  @relation(fields: [supplierId], references: [id])
  prices             ProductPrice[]
  variants           ProductVariant[] // <-- New: Tallas y Colores
  inventoryAuditItems InventoryAuditItem[]
  externalMaps       ExternalProductMap[]
  satKey             String?    // Clave de producto o servicio en el SAT
  satUnit            String?    // Clave de unidad de medida en el SAT

  @@unique([sku, branchId])
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute String   // Ej: "L - Rojo" o "32 GB"
  sku       String?
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  saleItems         SaleItem[]
  quoteItems        QuoteItem[]
  transferItems     TransferItem[]
  inventoryMovements InventoryMovement[]
  
  @@unique([productId, attribute])
}

model InventoryMovement {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  type        String   // "IN", "OUT", "ADJUSTMENT"
  quantity    Int      // Positive for additions, negative for subtractions
  reason      String   // Reason for the movement (e.g. "Initial Stock", "Sale #123")
  createdAt   DateTime @default(now())
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
}

model Sale {
  id          String     @id @default(uuid())
  total       Float
  status      String     @default("COMPLETED")
  paymentMethod String   @default("CASH")
  customer    Customer?  @relation(fields: [customerId], references: [id])
  customerId  String?
  branch      Branch?    @relation(fields: [branchId], references: [id])
  branchId    String?
  user        User       @relation(fields: [userId], references: [id])
  userId      String
  cashSessionId String?
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])
  
  // Novedades para Multi-pago y Notas
  notes       String?
  cashAmount  Float?
  cardAmount  Float?
  
  invoiceId   String?

  items       SaleItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SaleItem {
  id          String   @id @default(uuid())
  quantity    Int
  price       Float
  sale        Sale     @relation(fields: [saleId], references: [id])
  saleId      String
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
}

model Quote {
  id          String     @id @default(uuid())
  total       Float
  status      String     @default("PENDING")
  paymentMethod String   @default("CASH")
  customer    Customer?  @relation(fields: [customerId], references: [id])
  customerId  String?
  branch      Branch?    @relation(fields: [branchId], references: [id])
  branchId    String?
  user        User       @relation(fields: [userId], references: [id])
  userId      String
  items       QuoteItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model QuoteItem {
  id          String   @id @default(uuid())
  quantity    Int
  price       Float
  quote       Quote    @relation(fields: [quoteId], references: [id])
  quoteId     String
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
}

model Transfer {
  id             String         @id @default(uuid())
  branch         Branch?        @relation("TransferFrom", fields: [branchId], references: [id])
  branchId       String?
  toBranch       Branch?        @relation("TransferTo", fields: [toBranchId], references: [id])
  toBranchId     String?
  status         String         @default("IN_TRANSIT")
  items          TransferItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model TransferItem {
  id          String   @id @default(uuid())
  quantity    Int
  transfer    Transfer @relation(fields: [transferId], references: [id])
  transferId  String
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
}

model Promotion {
  id          String     @id @default(uuid())
  name        String
  type        String     @default("PERCENTAGE")
  value       Float      @default(0)
  active      Boolean    @default(true)
  branch      Branch     @relation(fields: [branchId], references: [id])
  branchId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Supplier {
  id        String     @id @default(uuid())
  name      String
  email     String?
  phone     String?
  street         String?
  exteriorNumber String?
  interiorNumber String?
  neighborhood   String?
  branchId  String?
  branch    Branch?    @relation(fields: [branchId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]
  products  Product[]

  // Datos Fiscales
  taxId       String?
  legalName   String?
  taxRegime   String?
  zipCode     String?
  cfdiUse     String?
  
  // Dirección adicional
  city        String?
  state       String?
  
  // Crédito
  creditLimit Float    @default(0)
  creditDays  Int      @default(0)
}

model Purchase {
  id            String         @id @default(uuid())
  branchId      String?
  branch        Branch?        @relation(fields: [branchId], references: [id])
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  supplierId    String?
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  total         Float
  paymentMethod String         @default("CASH") // CASH, CARD, TRANSFER
  status        String         @default("COMPLETED") // COMPLETED, PENDING
  createdAt     DateTime       @default(now())
  items         PurchaseItem[]
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Int
  cost       Float
}

model PriceList {
  id        String   @id @default(uuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  name      String   // e.g. "Público", "Mayoreo"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productPrices ProductPrice[]
}

model ProductPrice {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  price       Float
  
  @@unique([productId, priceListId])
}

model CashSession {
  id          String   @id @default(uuid())
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  openedAt    DateTime @default(now())
  closedAt    DateTime?
  
  initialAmount Float
  expectedAmount Float?
  actualAmount  Float?
  difference    Float? 
  
  status      String   @default("OPEN")
  
  movements   CashMovement[]
  sales       Sale[]
}

model CashMovement {
  id            String   @id @default(uuid())
  sessionId     String
  session       CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type          String   // IN, OUT
  amount        Float
  reason        String
  createdAt     DateTime @default(now())
}

model StoreIntegration {
  id           String   @id @default(uuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id])
  platform     String   // MERCADO_LIBRE, SHOPIFY, WOOCOMMERCE
  appId        String?
  clientSecret String?
  accessToken  String?
  refreshToken String?
  isActive     Boolean  @default(true)
  metadata     String?  // JSON context (like seller_id)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([branchId, platform])
}

model ExternalProductMap {
  id           String   @id @default(uuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  platform     String   // MERCADO_LIBRE
  externalId   String   // ID en la plataforma externa (MLM12345)
  syncStatus   String   @default("SYNCED") // UNSYNCED, SYNCED, ERROR
  lastSync     DateTime @default(now())

  @@unique([platform, externalId])
}

model Expense {
  id          String   @id @default(uuid())
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  category    String   // e.g., "Renta", "Nómina", "Luz", "Otros"
  amount      Float
  reason      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryAudit {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  name        String
  status      String   @default("COUNT_1") // COUNT_1, COUNT_2, COUNT_3, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  items       InventoryAuditItem[]
}

model InventoryAuditItem {
  id          String   @id @default(uuid())
  auditId     String
  audit       InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  productId   String
  product     Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  systemStock Int      // Frozen stock reading at beginning of audit
  
  count1      Int?     // Primer Conteo
  count2      Int?     // Segundo Conteo
  count3      Int?     // Tercer Conteo
  finalCount  Int?     // Resultado final para ajustar
}
